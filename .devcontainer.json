{
  "name": "Genomics V2F Reporter",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "shutdownAction": "none",
  "workspaceFolder": "/app",
  "remoteUser": "root",
  "forwardPorts": [8080],
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "50gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
